{
  "name": "kraken",
  "version": "0.1.0",
  "description": "Spec-Driven Development workbench powered by Claude",
  "main": "out/main/index.js",
  "author": "Kraken",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "postinstall": "electron-builder install-app-deps",
    "package:mac": "npm run build && electron-builder --mac --dir",
    "package:win": "npm run build && electron-builder --win --dir",
    "package:linux": "npm run build && electron-builder --linux --dir"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.11.0",
    "better-sqlite3": "^11.5.0",
    "electron-store": "^10.0.0",
    "gray-matter": "^4.0.3",
    "marked": "^14.1.3",
    "node-pty": "^1.1.0",
    "prismjs": "^1.30.0",
    "react-simple-code-editor": "^0.14.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.9.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "lucide-react": "^0.460.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "zustand": "^5.0.1"
  },
  "build": {
    "appId": "dev.kraken.app",
    "productName": "Kraken",
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "directories": {
      "buildResources": "resources"
    },
    "mac": {
      "category": "public.app-category.developer-tools"
    }
  }
}
