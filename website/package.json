{
  "name": "kraken-website",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5990 --strictPort",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 5990 --strictPort",
    "start": "vite preview --port 80 --strictPort",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t kraken-website .",
    "docker:run": "docker run --rm -p 80:80 kraken-website"
  },
  "dependencies": {
    "@xyflow/react": "^12.3.5",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.456.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.61.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
